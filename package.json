{
  "name": "vscode-review-relay",
  "displayName": "Review Relay",
  "description": "Live review comments shared between VS Code and local AI tools.",
  "version": "0.1.1",
  "publisher": "statiolake",
  "license": "MIT",
  "author": "statiolake",
  "repository": {
    "type": "git",
    "url": "https://github.com/statiolake/vscode-review-relay.git"
  },
  "homepage": "https://github.com/statiolake/vscode-review-relay#readme",
  "bugs": {
    "url": "https://github.com/statiolake/vscode-review-relay/issues"
  },
  "keywords": ["review", "comments", "coding agent", "AI", "diff"],
  "engines": { "vscode": "^1.96.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "reviewRelay", "title": "Review Relay", "icon": "media/icon.svg" }
      ]
    },
    "views": {
      "reviewRelay": [
        { "id": "reviewRelay.review", "name": "Review", "type": "webview" }
      ]
    },
    "commands": [
      { "command": "reviewRelay.addComment", "title": "Review Relay: Add Comment" },
      { "command": "reviewRelay.editComment", "title": "Edit", "icon": "$(edit)" },
      { "command": "reviewRelay.saveComment", "title": "Save", "icon": "$(check)" },
      { "command": "reviewRelay.cancelEditComment", "title": "Cancel", "icon": "$(close)" },
      { "command": "reviewRelay.deleteComment", "title": "Delete", "icon": "$(trash)" },
      { "command": "reviewRelay.submitComment", "title": "Add Comment" },
      { "command": "reviewRelay.copyEndpoint", "title": "Review Relay: Copy API Endpoint" },
      { "command": "reviewRelay.copyAgentInstructions", "title": "Review Relay: Copy Agent Instructions" },
      { "command": "reviewRelay.copyMarkdown", "title": "Review Relay: Copy as Markdown", "icon": "$(clippy)" },
      { "command": "reviewRelay.clearReview", "title": "Review Relay: Clear Review", "icon": "$(clear-all)" },
      { "command": "reviewRelay.clearComments", "title": "Review Relay: Clear All Comments" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "reviewRelay.submitComment", "when": "false" },
        { "command": "reviewRelay.editComment", "when": "false" },
        { "command": "reviewRelay.saveComment", "when": "false" },
        { "command": "reviewRelay.cancelEditComment", "when": "false" },
        { "command": "reviewRelay.deleteComment", "when": "false" }
      ],
      "editor/context": [
        { "command": "reviewRelay.addComment", "group": "navigation@50", "when": "editorTextFocus" }
      ],
      "comments/commentEditor/submit": [
        { "command": "reviewRelay.submitComment", "when": "commentController == review-relay" }
      ],
      "comments/comment/title": [
        { "command": "reviewRelay.editComment", "group": "inline@1", "when": "commentController == review-relay && comment == preview" },
        { "command": "reviewRelay.deleteComment", "group": "inline@2", "when": "commentController == review-relay && comment == preview" }
      ],
      "comments/comment/context": [
        { "command": "reviewRelay.saveComment", "group": "inline@1", "when": "commentController == review-relay && comment == editing" },
        { "command": "reviewRelay.cancelEditComment", "group": "inline@2", "when": "commentController == review-relay && comment == editing" }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run check && npm run build:cli:all && esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=dist/extension.js",
    "build": "npm run build:cli && esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=dist/extension.js",
    "build:cli": "node scripts/build-cli.mjs",
    "build:cli:all": "node scripts/build-cli.mjs --all",
    "package": "vsce package",
    "publish": "vsce publish",
    "check": "tsc --noEmit",
    "test": "npm run test:compile && node --test dist-test/test/**/*.test.js && go test ./...",
    "test:compile": "tsc -p tsconfig.test.json"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2"
  }
}
